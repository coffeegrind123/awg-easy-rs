# Vendored binary blobs are CI artifacts, not source. They're produced
# by scripts/build.sh (or the Build and Release workflow) from the
# audited pin files in vendor/*_VERSION. Keeps the repo small and
# forces every release to rebuild from the pinned source list.
/vendor/*.gz
